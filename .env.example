# Copy this file to .env and fill in your keys.
# Never commit .env to git.

# Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# OpenAI — https://platform.openai.com
OPENAI_API_KEY=your_openai_key_here

# Google — https://aistudio.google.com
GEMINI_API_KEY=your_gemini_key_here

# NVIDIA NIM (free) — https://build.nvidia.com
# One key covers all NIM models; set the same value for each.
TASEF_KEY_MISTRAL=your_nim_key_here
TASEF_KEY_NEMOTRON=your_nim_key_here
TASEF_KEY_QWEN=your_nim_key_here
TASEF_KEY_LLAMA=your_nim_key_here
TASEF_KEY_GEMMA=your_nim_key_here
TASEF_KEY_KIMI=your_nim_key_here
